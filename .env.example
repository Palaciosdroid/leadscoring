# -------------------------------------------------------
# SBC Lead Scoring Engine — Environment Variables
# Copy to .env and fill in before deploying to Railway
# NEVER commit .env to git
# -------------------------------------------------------

# HubSpot Private App token
# Dashboard → Settings → Integrations → Private Apps
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token_here

# Customer.io App API Key (for batch re-scoring via App API)
# app.customer.io → Settings → API Credentials → App API Keys
# Create a dedicated key named "sbc-lead-scorer"
CIO_APP_API_KEY=your_customer_io_app_api_key_here

# Customer.io Webhook Secret (optional, for signature verification)
# app.customer.io → Settings → Integrations → Reporting Webhooks
CIO_WEBHOOK_SECRET=

# Aircall Power Dialer
# dashboard.aircall.io → Integrations & API → API Keys
AIRCALL_API_ID=your_aircall_api_id_here
AIRCALL_API_TOKEN=your_aircall_api_token_here
# Power Dialer Lists (create 2 lists in Aircall Dashboard → Power Dialer)
# Closer works: fresh first → then warm
AIRCALL_LIST_FRESH=               # opt-in < 24h → list name: "fresh"
AIRCALL_LIST_WARM=                # Score ≥ 50   → list name: "warm"

# Slack Incoming Webhook URL
# api.slack.com → Your Apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Batch scoring interval (minutes, default: 30)
BATCH_INTERVAL_MINUTES=30

# Re-score leads active within last N days (default: 30)
RESCORE_WINDOW_DAYS=30

# Optional: path to trained AI model pickle (activate after 100+ conversions)
# AI_MODEL_PATH=lead_scoring_model.pkl
